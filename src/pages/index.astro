---
import Base from '../layouts/Base.astro';
---
<Base title="BeWildfireAware" active="home">
  <main>
    <section class="hero">
      <h1>Be Wildfire Aware</h1>
      <p>Stay informed and stay safe</p>
    </section>

    <section class="dispatch-areas" id="dispatch-areas">
      <h2>Dispatch Areas</h2>
      <p>Explore the current wildfire danger in your area.</p>
      <a href="/dispatch_areas/dispatch_areas.html" class="cta">Explore Dispatch Areas</a>
    </section>
  </main>

  <section class="fems-attribution">
    <div class="fems-content">
      <img src="/Data/FEMS_logo.png" alt="FEMS Logo" class="fems-logo" />
      <p><strong>Weather and NFDRS data now coming from FEMS</strong></p>
    </div>
  </section>
</Base>
